{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "outDir": "./build",
    "rootDir": "./src",
    "lib": ["ES2020", "DOM"],
    "noImplicitAny": false
  },
  "include": [
    "src/engine/LuxuryEngine.ts",
    "src/engine/TripleSevenEngine.ts",
    "src/engine/DoubleUpKenoEngine.ts",
    "src/engine/MersenneTwister.ts",
    "src/utils/meters.ts",
    "src/utils/winTier.ts",
    "src/utils/creditStorage.ts"
  ],
  "exclude": ["node_modules"]
}
